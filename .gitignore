# Temporary and operating system files
.DS_Store
Thumbs.db
*.tmp
*.log
*.bak
*.swp

# Local IDE settings
.vscode/
.idea/
*.iml

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env

# Large or sensitive captures (wireshark/ track)
# Anonymized, reasonably sized captures can be versioned normally
# inside labs/**/captures/. The patterns below prevent the accidental
# versioning of raw, private, or sensitive material.
*.private.pcap
*.private.pcapng
*.sensitive.pcap
*.sensitive.pcapng
captures/raw/
*.pcapng.gz
*.pcap.gz

# Large or sensitive scan outputs (nmap/ track)
# The same principle applies to labs/**/outputs/: only already
# reviewed and anonymized outputs should be versioned.
*.private.xml
*.private.gnmap
*.sensitive.xml
*.sensitive.gnmap
outputs/raw/
